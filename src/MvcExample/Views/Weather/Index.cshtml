@model MvcExample.Core.WeatherViewModel
@{
    ViewBag.Title = "Weather";
}

<div class="p-5 mb-4 bg-light rounded-3">
    <div class="container-fluid py-4">
        <h1 class="display-6">Weather Demo</h1>
        <p class="lead">
            This page will show live weather data retrieved through
            <code>DGates.AwsSecretsManager</code>, using an OpenWeatherMap API key stored in
            AWS Secrets Manager.
        </p>
    </div>
</div>

@if (!Model.IsConfigured)
{
    <div class="alert alert-warning">@Model.ConfigurationMessage</div>
}
else
{
    using (Html.BeginForm("Index", "Weather", FormMethod.Post))
    {
        <div class="input-group mb-3" style="max-width: 400px;">
            <input type="text" name="cityName" class="form-control" placeholder="Enter a city name"
                   value="@Model.CityName" required="required" />
            <button class="btn btn-primary" type="submit">Get Weather</button>
        </div>
    }

    if (!Model.HasResult && string.IsNullOrEmpty(Model.ErrorMessage) && !string.IsNullOrEmpty(Model.SecretName))
    {
        <p class="small text-muted">
            Secret <code>@Model.SecretName</code> retrieved from @Model.Source.
        </p>
    }

    if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    if (Model.HasResult)
    {
        <div class="card" style="max-width: 400px;">
            <div class="card-body">
                <h5 class="card-title">@Model.Location</h5>
                <h6 class="card-subtitle mb-2 text-muted">@Model.Description</h6>
                <p class="card-text">
                    Temperature: @Model.Temperature&deg;F (feels like @Model.FeelsLike&deg;F)<br />
                    Humidity: @Model.Humidity%<br />
                    Pressure: @Model.Pressure hPa<br />
                    Wind speed: @Model.WindSpeed mph
                </p>
            </div>
        </div>

        <div class="alert alert-secondary small mt-3" style="max-width: 400px;">
            <strong>How this worked</strong>
            <hr class="my-2" />
            Secret: <code>@Model.SecretName</code><br />
            Retrieved URL: <code>@Model.RetrievedUrl</code><br />
            Source: @Model.Source
        </div>
    }
}

@section pageFooter {
    <p class="text-muted">
        This app demonstrates <a href="https://github.com/dgates82/DGates.AwsSecretsManager">DGates.AwsSecretsManager</a> —
        a typed, cached AWS Secrets Manager wrapper for .NET Framework 4.8. It retrieves an OpenWeatherMap
        API key from Secrets Manager via <code>SecretsManagerServiceFactory</code> and uses it to power the search above.
    </p>
}
