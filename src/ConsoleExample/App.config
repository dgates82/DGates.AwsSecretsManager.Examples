<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- LocalStack endpoint for local development; remove/leave empty for real AWS -->
    <add key="AWSServiceURL" value="http://localhost:4566" />
    <add key="AWSRegion" value="us-west-2" />
    <!-- LocalStack accepts any non-empty value for credentials -->
    <add key="AWSAccessKey" value="test" />
    <add key="AWSSecretKey" value="test" />
    <add key="Secrets:DbConfigName" value="dev/ConsoleExample/DbConfig" />
  </appSettings>
</configuration>
